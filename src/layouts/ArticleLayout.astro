---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  readTime: string;
  canonical?: string;
  /** Fecha de ultima revision (ISO). Por defecto = date (no revisado desde publicacion). */
  dateModified?: string;
  /** Imagen destacada para el schema. Por defecto, la imagen social del sitio. */
  image?: string;
  /** Schema EXTRA de la pagina (FAQPage, HowTo...). Se fusiona con el BlogPosting. */
  schema?: object | object[];
  /** Borradores: noindex hasta que el copy este listo. */
  noindex?: boolean;
}

const {
  title,
  description,
  date,
  category,
  readTime,
  canonical,
  dateModified,
  image = 'https://gmvsolutions.es/factory-bg.jpg',
  schema,
  noindex = false,
} = Astro.props;

const dateFormatted = new Date(date).toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const articleUrl = canonical ?? Astro.url.href;

// Autor real del blog (E-E-A-T + humaniza el copy frente a detectores de IA).
// Person con sameAs a LinkedIn; reutilizado en el byline visible y en el JSON-LD.
const author = {
  name: 'Gonzalo Moldes',
  role: 'Fundador de REELEVO',
  url: 'https://www.linkedin.com/in/gonzalomoldes/',
  initials: 'GM',
  bio: 'Escribo desde lo que veo en planta: cómo se pierde el conocimiento cuando falta la persona clave, y qué hace que un relevo o una incorporación no frenen el turno. Sin teoría de manual.',
};

// BlogPosting canonico generado en un solo sitio para todo el blog (S2: unificacion
// de schema). Antes cada articulo emitia su propio Article con autor Organization.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date,
  dateModified: dateModified ?? date,
  articleSection: category,
  inLanguage: 'es-ES',
  url: articleUrl,
  mainEntityOfPage: articleUrl,
  image,
  author: {
    '@type': 'Person',
    name: author.name,
    jobTitle: author.role,
    url: author.url,
    sameAs: [author.url],
  },
  publisher: { '@id': 'https://gmvsolutions.es/#organization' },
};

// El schema que pase la pagina se trata como EXTRA (FAQ, HowTo...) y se fusiona.
const extraSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const mergedSchema = [articleSchema, ...extraSchema];

// El BreadcrumbList se genera de forma global y automatica en BaseLayout (src/lib/seo.ts),
// que ademas produce la ruta correcta (Inicio -> Blog -> articulo). No se duplica aqui.
---

<BaseLayout title={title} description={description} canonical={canonical} schema={mergedSchema} activeNav="blog" pageType="blog" noindex={noindex}>
  <article class="article-page">
    <div class="article-container">

      <header class="article-header">
        <div class="article-category">{category}</div>
        <h1 class="article-title">{title}</h1>
        <div class="article-meta">
          <span class="article-date">{dateFormatted}</span>
          <span class="article-sep">·</span>
          <span class="article-time">⏱️ {readTime} lectura</span>
        </div>
        <div class="article-author">
          <div class="article-author-avatar" aria-hidden="true">{author.initials}</div>
          <div class="article-author-meta">
            <a class="article-author-name" href={author.url} target="_blank" rel="author noopener">{author.name}</a>
            <span class="article-author-role">{author.role}</span>
            <p class="article-author-bio">{author.bio}</p>
          </div>
        </div>
      </header>

      <div class="article-body">
        <slot />
      </div>

      <div class="article-back">
        <a href="/blog/" class="btn-ghost">← Volver al blog</a>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    padding: 120px 24px 80px;
  }

  .article-container {
    max-width: 980px;
    margin: 0 auto;
    background: rgba(60, 60, 60, 0.95);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 48px 48px 40px;
  }

  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .75rem;
    color: var(--gray2);
    margin-bottom: 40px;
  }

  .article-breadcrumb a {
    color: var(--gray);
    text-decoration: none;
    transition: color .2s;
  }

  .article-breadcrumb a:hover {
    color: var(--orange);
  }

  .article-category {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .article-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .02em;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .82rem;
    color: var(--gray);
    margin-bottom: 56px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .article-sep { color: var(--gray2); }

  .article-author {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-top: -32px;
    margin-bottom: 44px;
  }

  .article-author-avatar {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--orange);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Oswald', sans-serif;
    font-weight: 600;
    font-size: .95rem;
    letter-spacing: .04em;
  }

  .article-author-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .article-author-name {
    font-family: 'Oswald', sans-serif;
    font-size: .98rem;
    font-weight: 600;
    letter-spacing: .02em;
    color: var(--white);
    text-decoration: none;
    width: fit-content;
  }

  .article-author-name:hover {
    color: var(--orange);
  }

  .article-author-role {
    font-family: 'DM Mono', monospace;
    font-size: .62rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .article-author-bio {
    font-size: .82rem;
    color: var(--gray);
    line-height: 1.6;
    margin: 6px 0 0;
    max-width: 60ch;
  }

  /* Prose */
  .article-body :global(h2) {
    font-family: 'Oswald', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin: 48px 0 16px;
    line-height: 1.2;
  }

  .article-body :global(h2:first-child) {
    margin-top: 0;
  }

  .article-body :global(h3) {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    color: rgba(255,255,255,.85);
    margin: 32px 0 12px;
  }

  .article-body :global(p) {
    font-size: 17px;
    color: rgba(255,255,255,.8);
    line-height: 1.75;
    margin-bottom: 20px;
  }

  .article-body :global(p em) {
    font-size: .82rem;
    color: var(--gray);
    font-style: normal;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
  }

  .article-body :global(li) {
    font-size: 17px;
    color: rgba(255,255,255,.8);
    line-height: 1.7;
    margin-bottom: 8px;
  }

  .article-body :global(strong) {
    color: var(--white);
    font-weight: 500;
  }

  .article-body :global(a) {
    color: var(--orange);
    text-decoration: none;
    border-bottom: 1px solid rgba(244,82,30,.3);
    transition: border-color .2s;
  }

  .article-body :global(a:hover) {
    border-color: var(--orange);
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }

  /* Data card */
  .article-body :global(.data-card) {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--orange);
    border-radius: 4px;
    padding: 28px 32px;
    margin: 28px 0;
  }

  .article-body :global(.data-card p) {
    font-size: .9rem;
    line-height: 1.7;
    margin-bottom: 12px;
    color: rgba(255,255,255,.85);
  }

  .article-body :global(.data-card p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(.data-card strong) {
    color: var(--orange);
    font-size: 1rem;
  }

  /* Highlight box */
  .article-body :global(.highlight-box) {
    background: rgba(244,82,30,.08);
    border: 1px solid rgba(244,82,30,.25);
    border-radius: 4px;
    padding: 28px 32px;
    margin: 40px 0;
  }

  .article-body :global(.highlight-box p) {
    font-size: .9rem;
    line-height: 1.7;
    margin-bottom: 12px;
    color: rgba(255,255,255,.85);
  }

  .article-body :global(.highlight-box p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(.highlight-box strong) {
    color: var(--white);
  }

  .article-body :global(.highlight-box a) {
    color: var(--orange);
    font-weight: 500;
    border-bottom: none;
  }

  .article-body :global(.related-links) {
    margin: 48px 0 40px;
    padding: 28px 32px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .article-body :global(.related-links-label) {
    font-family: 'DM Mono', monospace;
    font-size: .62rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .article-body :global(.related-links-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .article-body :global(.related-link-card) {
    display: block;
    text-decoration: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 18px;
    transition: border-color .2s, transform .2s;
  }

  .article-body :global(.related-link-card:hover) {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .article-body :global(.related-link-kicker) {
    font-family: 'DM Mono', monospace;
    font-size: .62rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--gray2);
    margin-bottom: 10px;
  }

  .article-body :global(.related-link-title) {
    font-family: 'Oswald', sans-serif;
    font-size: .95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    line-height: 1.25;
    margin-bottom: 10px;
    color: var(--white);
  }

  .article-body :global(.related-link-desc) {
    font-size: .82rem;
    line-height: 1.55;
    color: var(--gray);
    margin-bottom: 0;
  }

  .article-back {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 900px) {
    .article-body :global(.related-links-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
