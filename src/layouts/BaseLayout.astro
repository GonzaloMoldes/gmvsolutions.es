---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GaliciaSeal from '../components/GaliciaSeal.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { organizationSchema, buildBreadcrumb } from '../lib/seo';
import '../styles/global.css';
import entryLogo from '../../reelevo-brand-logo-transparent-shadow.png';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  activeNav?: string;
  schema?: object | object[];
  pageType?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogTitle = title,
  ogDescription = description,
  ogImage = 'https://gmvsolutions.es/factory-bg.jpg',
  activeNav,
  schema,
  pageType,
  noindex = false,
} = Astro.props;

// Schema sitewide (S1-C3): Organization en todas las paginas + BreadcrumbList
// generado automaticamente desde la ruta. La home omite breadcrumb.
const breadcrumbSchema = buildBreadcrumb(Astro.url.pathname);
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <script is:inline>
    (() => {
      const root = document.documentElement;
      const splashKey = 'reelevo-entry-splash-seen';

      root.classList.add('entry-splash-booting');

      try {
        if (window.sessionStorage.getItem(splashKey) !== '1') {
          root.classList.add('show-entry-splash');
          window.sessionStorage.setItem(splashKey, '1');
        }
      } catch {
        root.classList.add('show-entry-splash');
      } finally {
        root.classList.remove('entry-splash-booting');
      }
    })();
  </script>

  <style is:inline>
    html,
    body {
      background: #000;
    }

    html.entry-splash-booting body {
      overflow: hidden;
    }

    html.entry-splash-booting .site-shell,
    html.show-entry-splash .site-shell {
      opacity: 0 !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }

    html.entry-splash-booting .entry-splash {
      opacity: 0 !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }

    html.show-entry-splash .entry-splash {
      opacity: 1 !important;
      visibility: visible !important;
      pointer-events: none !important;
    }
  </style>

  <!-- Cookiebot -->
  <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="555982fb-7d04-4596-8a45-fa2d446a3892" data-blockingmode="auto" type="text/javascript"></script>
  
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-M223Z398');</script>
    <!-- End Google Tag Manager -->

  <!-- Google tag (gtag.js) — GA4 + Google Ads -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-JJCZ6M3T8Y"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-JJCZ6M3T8Y');
    gtag('config', 'AW-18000536518');
  </script>

  <!-- Microsoft Clarity -->
  <script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "x6zuugdflb");
  </script>

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:160, max-image-preview:large, max-video-preview:-1'} />
  <meta name="author" content="GMV Solutions" />
  <meta name="theme-color" content="#F4521E" />
  <link rel="canonical" href={canonical} />
  <!-- hreflang: arquitectura lista (hoy solo ES). Al abrir EN/PT, anadir sus alternates aqui. -->
  <link rel="alternate" hreflang="es" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="REELEVO by GMV Solutions" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="es_ES" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Schema.org: Organization sitewide + BreadcrumbList auto + schema de pagina -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  {breadcrumbSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  )}
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- Google Fonts (carga asíncrona, fuera de la ruta crítica) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400;500&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400;500&display=swap"
    />
  </noscript>

  <!-- Slot for page-specific head content (extra schema, etc.) -->
  <slot name="head" />
</head>

<body data-page-type={pageType}>
  <div class="entry-splash" aria-hidden="true">
    <div class="entry-splash__logo-wrap">
      <img
        class="entry-splash__logo"
        src={entryLogo.src}
        width={entryLogo.width}
        height={entryLogo.height}
        alt=""
        decoding="async"
      />
    </div>
  </div>

  <div class="site-shell">
    <div class="hero-bg"></div>
    <Header activeNav={activeNav} />
    <GaliciaSeal />

    <main style="position:relative;">
      <Breadcrumbs />
      <slot />
    </main>

    <Footer />
  </div>

  <!-- Tracking de CTAs (S1-C7): listener delegado -> dataLayer -> GA4/Ads via GTM -->
  <script is:inline>
    (() => {
      const LEAD_INTENTS = ['registro', 'diagnostico', 'demo', 'contacto'];
      document.addEventListener('click', (e) => {
        const cta = e.target.closest('[data-cta]');
        if (!cta) return;
        const intent = cta.dataset.ctaIntent || 'otro';
        const payload = {
          cta_id: cta.id || null,
          cta_label: cta.dataset.ctaLabel || (cta.textContent || '').trim(),
          cta_location: cta.dataset.ctaLocation || 'body',
          cta_intent: intent,
          cta_destination: cta.getAttribute('href'),
          page_path: location.pathname,
          page_type: document.body.dataset.pageType || null,
        };
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'cta_click', ...payload });
        if (LEAD_INTENTS.includes(intent)) {
          window.dataLayer.push({ event: 'generate_lead', lead_type: intent, ...payload });
        }
      });
    })();
  </script>

  <script is:inline>
    (() => {
      const root = document.documentElement;
      const logoRevealDelay = 220;
      const pulseDuration = 3000;
      const zoomDuration = 920;
      const blackoutHold = 180;
      const totalDuration = logoRevealDelay + pulseDuration + zoomDuration + blackoutHold;

      // Retira el splash y, con el, devuelve la interaccion a la pagina.
      const clearSplash = () => {
        root.classList.remove('entry-splash-zoom');
        root.classList.remove('entry-splash-logo-visible');
        root.classList.remove('show-entry-splash');
      };

      // Failsafe global: el splash nunca debe bloquear la interaccion mas alla de
      // su duracion prevista, pase lo que pase con los timers de animacion.
      // - visibilitychange: si la pestana cargo en segundo plano (timers throttled)
      //   o se restaura el foco, limpiamos poco despues de volver a verla.
      // - pageshow persisted: restauracion desde bfcache (atras/adelante).
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible' && root.classList.contains('show-entry-splash')) {
          window.setTimeout(clearSplash, 1500);
        }
      });
      window.addEventListener('pageshow', (e) => {
        if (e.persisted) clearSplash();
      });

      if (!root.classList.contains('show-entry-splash')) {
        return;
      }

      window.setTimeout(() => {
        root.classList.add('entry-splash-logo-visible');
      }, logoRevealDelay);

      window.setTimeout(() => {
        root.classList.add('entry-splash-zoom');
      }, logoRevealDelay + pulseDuration);

      window.setTimeout(clearSplash, totalDuration);

      // Backstop absoluto por si algun setTimeout intermedio no se ejecuta.
      window.setTimeout(clearSplash, totalDuration + 800);
    })();
  </script>
</body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M223Z398"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
</html>
