---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Software español para digitalizar la planta industrial | REELEVO";
const description = "Software español para digitalizar la planta industrial: control de producción, continuidad ante bajas y trazabilidad de ejecución, sin la complejidad de un MES. Desde 49€/mes por empresa.";
const canonical = "https://gmvsolutions.es/";

// La Organization se emite globalmente desde BaseLayout (src/lib/seo.ts).
// Aqui: WebSite (propio de la home) + SoftwareApplication con oferta (S2-C1).
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "REELEVO",
    "url": "https://gmvsolutions.es"
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": "https://gmvsolutions.es/#software",
    "name": "REELEVO",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web, Android, iOS",
    "inLanguage": "es-ES",
    "description": description,
    "url": "https://gmvsolutions.es/",
    "publisher": { "@id": "https://gmvsolutions.es/#organization" },
    "featureList": [
      "Procedimientos en el puesto sin cuenta de operario",
      "Registro verificable de ejecución",
      "Monitor de actividad de turno",
      "Gestión de competencias",
      "Modo offline"
    ],
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "EUR",
      "lowPrice": "49",
      "highPrice": "149",
      "offerCount": "3",
      "offers": [
        {
          "@type": "Offer",
          "name": "Starter",
          "price": "49",
          "priceCurrency": "EUR",
          "url": "https://app.gmvsolutions.es/registro",
          "priceSpecification": {
            "@type": "UnitPriceSpecification",
            "price": "49",
            "priceCurrency": "EUR",
            "billingIncrement": "1",
            "unitText": "MES / EMPRESA"
          }
        },
        {
          "@type": "Offer",
          "name": "Profesional",
          "price": "149",
          "priceCurrency": "EUR",
          "url": "https://app.gmvsolutions.es/registro",
          "priceSpecification": {
            "@type": "UnitPriceSpecification",
            "price": "149",
            "priceCurrency": "EUR",
            "billingIncrement": "1",
            "unitText": "MES / EMPRESA"
          }
        }
      ]
    },
    "potentialAction": [
      {
        "@type": "RegisterAction",
        "name": "Registrarse en REELEVO",
        "target": "https://app.gmvsolutions.es/registro"
      },
      {
        "@type": "AssessAction",
        "name": "Diagnóstico de riesgo operativo",
        "target": "https://diagnostico.gmvsolutions.es"
      }
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema} activeNav="" pageType="core">

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-eyebrow fade-up">Software español para digitalizar la planta industrial en pymes</div>
    <h1 class="hero-title fade-up delay-1">
      Controla tu planta<br>
      sin complejidad<br>
      <em>de un sistema MES</em>.
    </h1>
    <p class="hero-sub fade-up delay-2">
      Tu planta depende de dos o tres personas. Si una falta un martes a las seis, lo notas en la línea. REELEVO pone lo que saben en el puesto, para que el turno siga sin ellas.
    </p>
    <div class="hero-actions fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary"
         data-cta data-cta-intent="registro" data-cta-location="hero" data-cta-label="Registrarme en REELEVO">Registrarme en REELEVO</a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost"
         data-cta data-cta-intent="diagnostico" data-cta-location="hero" data-cta-label="Evaluar mi situacion">Evaluar mi situación</a>
    </div>
    <div class="hero-proof fade-up delay-4">
      <div class="hero-proof-item">
        <div class="hero-proof-num">Continuidad</div>
        <div class="hero-proof-label">menos dependencia cuando falta alguien</div>
      </div>
      <div class="hero-proof-item">
        <div class="hero-proof-num">Visibilidad</div>
        <div class="hero-proof-label">seguimiento diario de la operacion</div>
      </div>
      <div class="hero-proof-item">
        <div class="hero-proof-num">49€</div>
        <div class="hero-proof-label">al mes por empresa</div>
      </div>
    </div>
  </section>

    <!-- ═══ POSICIONAMIENTO ═══ -->
    <section class="section">
      <div class="section-inner">
        <p class="section-sub fade-up" style="text-align:center;max-width:780px;margin:0 auto;">
          REELEVO es el <strong>software español para digitalizar la planta industrial</strong> de las pymes:
          lleva el control de producción, la continuidad ante bajas y la trazabilidad de ejecución al puesto
          de trabajo, sin la complejidad de implantar un MES.
        </p>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ EL PROBLEMA ═══ -->
    <section class="section" id="casos">
      <div class="section-inner">
        <div class="casos-header fade-up">
          <div class="eyebrow">El día a día</div>
          <h2 class="section-title">Que problema resuelve REELEVO</h2>
          <p class="section-sub">
            Bajas, incorporaciones y turnos sin trazabilidad. Ese es el foco principal.
          </p>
        </div>

        <div class="casos fade-up delay-1">
          <div class="caso">
            <div class="caso-tag">El experto no ha venido</div>
            <h3 class="caso-title">
              «Javi está de baja.<br>
              ¿Quién arranca<br>
              la llenadora?»
            </h3>
            <p class="caso-desc">
              Es martes a las 6:30. Javi lleva 15 años en esa máquina y hoy está en urgencias.
              Su sustituto no domina el proceso. La línea no arranca hasta que alguien
              encuentre la solución o hasta que Javi coja el teléfono.
            </p>
            <ul class="caso-benefits">
              <li>Horas de línea parada buscando quién sabe arrancarla</li>
              <li>Errores por improvisar sin instrucciones claras</li>
              <li>Llamadas al experto durante su baja para salir del paso</li>
            </ul>
          </div>

          <div class="caso">
            <div class="caso-tag">Incorporación nueva</div>
            <h3 class="caso-title">
              «Es su primer día.<br>
              Alguien tiene que<br>
              enseñarle.»
            </h3>
            <p class="caso-desc">
              Llega alguien nuevo — fijo, personal de ETT, lo que sea — y necesita aprender el puesto.
              Uno de tus mejores operarios deja su máquina para hacer de tutor durante días.
              Dos personas ocupadas, un solo puesto produciendo.
            </p>
            <ul class="caso-benefits">
              <li>Tu mejor operario pierde tiempo productivo enseñando</li>
              <li>El aprendizaje depende de quién enseña y cómo</li>
              <li>En campañas o picos, se multiplica con cada ETT nuevo</li>
            </ul>
          </div>

          <div class="caso">
            <div class="caso-tag">La operación diaria</div>
            <h3 class="caso-title">
              «¿Quién hizo qué<br>
              ayer en la línea 3<br>
              y con qué resultado?»
            </h3>
            <p class="caso-desc">
              La producción pasa, pero no queda registro. No sabes quién ejecutó el proceso,
              si siguió los pasos correctos, si hubo incidencias o cuántas unidades salieron realmente.
              Decides sobre estimaciones, no sobre datos.
            </p>
            <ul class="caso-benefits">
              <li>Sin trazabilidad de quién hizo qué ni cuándo</li>
              <li>Decisiones de producción basadas en intuición</li>
              <li>Dependes de reuniones y llamadas para saber el estado real</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ DATOS ═══ -->
    <section class="section section-center">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">Lo que dicen los números</div>
          <h2 class="section-title">El coste que nadie mide</h2>
          <p class="section-sub">
            Son datos del sector industrial español. La mayoría de pymes industriales y talleres
            asumen esto como "normal". No lo es.
          </p>
        </div>

        <div class="dolor-grid fade-up delay-1">
          <div class="dolor-item">
            <div class="dolor-num">7,2<sup>%</sup></div>
            <div class="dolor-label">
              <strong>Tasa de absentismo</strong> media en pymes industriales.
              1 de cada 14 trabajadores falta cada día.
            </div>
          </div>
          <div class="dolor-item">
            <div class="dolor-num">3-5</div>
            <div class="dolor-label">
              <strong>Días de aprendizaje</strong> hasta que una incorporación nueva
              rinde como el operario titular.
            </div>
          </div>
          <div class="dolor-item">
            <div class="dolor-num">40<sup>%</sup></div>
            <div class="dolor-label">
              <strong>De jefes de planta</strong> llaman directamente al experto
              cuando alguien falta. Aunque esté de baja.
            </div>
          </div>
        </div>

        <div class="dolor-cta fade-up delay-2">
          <a href="https://diagnostico.gmvsolutions.es" class="btn-primary"
             data-cta data-cta-intent="diagnostico" data-cta-location="body" data-cta-label="Evaluar mi situacion">
            Evaluar mi situación →
          </a>
          <div class="dolor-cta-note">
            Calculadora gratuita · Resultado en 2 minutos
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ PRODUCTO EN ACCIÓN ═══ -->
    <section class="section section-center" id="producto">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">El producto</div>
          <h2 class="section-title">Esto es lo que <em>verás en tu planta</em></h2>
          <p class="section-sub">
            Panel para empresa, vista de trabajo en el puesto y visibilidad de actividad.
            No es solo "consultar una guía": es que quien entra a cubrir un puesto sepa qué hacer sin frenar al resto del equipo.
          </p>
        </div>

        <div class="screenshots-wrap fade-up delay-1">
          <div class="screenshots-track" id="screenshotsTrack">
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/admin-dashboard.png" alt="Panel empresa REELEVO con procesos, máquinas y configuración operativa" loading="lazy">
              </div>
              <div class="screenshot-caption">Panel empresa — visión diaria de procesos, puestos y estado operativo</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/sop-operario.png" alt="Vista operario REELEVO con acceso a proceso desde el puesto" loading="lazy">
              </div>
              <div class="screenshot-caption">Vista del operario — el trabajo aparece en el puesto cuando hace falta, sin fricción innecesaria</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/monitor-actividad.png" alt="Monitor de actividad REELEVO" loading="lazy">
              </div>
              <div class="screenshot-caption">Vista de producción — actividad del turno para decidir antes de que el problema escale</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/planificacion-semanal.png" alt="Planificación semanal de operarios" loading="lazy">
              </div>
              <div class="screenshot-caption">Planificación semanal — asignación visual de tareas y turnos</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/gestion-productos-procesos.png" alt="Gestión de productos y procesos" loading="lazy">
              </div>
              <div class="screenshot-caption">Gestión de productos — definición de procesos y combinaciones</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/equipo-operaciones.png" alt="Panel de equipo de operaciones" loading="lazy">
              </div>
              <div class="screenshot-caption">Equipo de operaciones — seguimiento de actividad y competencias</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/competencias-operario.png" alt="Detalle de competencias de operario" loading="lazy">
              </div>
              <div class="screenshot-caption">Detalle de competencias — certificaciones y habilidades de operario</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/analitica-productividad.png" alt="Panel de productividad y analítica" loading="lazy">
              </div>
              <div class="screenshot-caption">Productividad — analítica de procesos y rendimiento</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/detalle-procesos.png" alt="Detalle de procesos y tiempos" loading="lazy">
              </div>
              <div class="screenshot-caption">Detalle de procesos — tiempos, pasos y eficiencia</div>
            </div>
          </div>
          <button class="carousel-btn carousel-prev" id="carPrev" aria-label="Anterior">←</button>
          <button class="carousel-btn carousel-next" id="carNext" aria-label="Siguiente">→</button>
          <div class="carousel-dots" id="carDots">
            <button class="carousel-dot is-active" aria-label="Pantalla 1"></button>
            <button class="carousel-dot" aria-label="Pantalla 2"></button>
            <button class="carousel-dot" aria-label="Pantalla 3"></button>
            <button class="carousel-dot" aria-label="Pantalla 4"></button>
            <button class="carousel-dot" aria-label="Pantalla 5"></button>
            <button class="carousel-dot" aria-label="Pantalla 6"></button>
            <button class="carousel-dot" aria-label="Pantalla 7"></button>
            <button class="carousel-dot" aria-label="Pantalla 8"></button>
            <button class="carousel-dot" aria-label="Pantalla 9"></button>
          </div>
        </div>

        <div class="visual-proof-grid fade-up delay-2">
          <article class="visual-proof-card">
            <div class="visual-proof-tag">En el puesto</div>
            <h3 class="visual-proof-title">El sustituto no arranca a ciegas</h3>
            <p class="visual-proof-desc">
              El sustituto abre el puesto y el proceso ya está ahí. No llama a nadie.
              No espera a que Javi conteste el móvil desde casa. Arranca.
            </p>
          </article>

          <article class="visual-proof-card">
            <div class="visual-proof-tag">Para producción</div>
            <h3 class="visual-proof-title">Producción decide con el turno a la vista</h3>
            <p class="visual-proof-desc">
              Producción ve el turno mientras pasa, no en la reunión del día siguiente.
              Si la línea 3 se atasca, te enteras cuando todavía puedes mover a alguien.
            </p>
          </article>

          <article class="visual-proof-card">
            <div class="visual-proof-tag">Para seguimiento</div>
            <h3 class="visual-proof-title">El trabajo deja una base útil</h3>
            <p class="visual-proof-desc">
              Cada proceso ejecutado deja rastro: quién lo hizo, cuándo y cuánto tardó.
              Cuando llega la auditoría de calidad —o se jubila el de toda la vida— no empiezas de cero.
            </p>
          </article>
        </div>

        <div class="screenshots-cta fade-up delay-3">
          <a href="https://app.gmvsolutions.es/registro" class="btn-ghost"
             data-cta data-cta-intent="registro" data-cta-location="body" data-cta-label="Registrarme en REELEVO">Registrarme en REELEVO →</a>
        </div>
      </div>
    </section>

    <div class="divider"></div>


    <!-- ═══ BENEFICIOS ═══ -->
    <section class="section section-center" id="beneficios">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">Lo que cambia en planta</div>
          <h2 class="section-title">Impacto operativo <em>que se nota rápido</em></h2>
          <p class="section-sub">
            Empiezas por pocos procesos críticos y lo notas en el día a día:
            menos paradas por dudas, menos dependencia del tutor y más claridad para mover el turno.
          </p>
        </div>

        <div class="benefits-grid fade-up delay-1">
          <div class="benefit-card">
            <div class="benefit-card-icon">⚡</div>
            <h3 class="benefit-card-title">El proceso aparece donde hace falta</h3>
            <p class="benefit-card-desc">
              Quien cubre el puesto no pierde media hora buscando cómo se arranca: lo tiene delante,
              paso a paso. Y deja de sonar el «espera, que ahora te explico» a mitad de turno.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-card-icon">🧾</div>
            <h3 class="benefit-card-title">Más claridad para producción</h3>
            <p class="benefit-card-desc">
              Producción deja de decidir de oído. Ve qué está pasando en cada puesto
              sin bajar a preguntar ni esperar al parte de la tarde.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-card-icon">📊</div>
            <h3 class="benefit-card-title">Menos tiempo perdido</h3>
            <p class="benefit-card-desc">
              Se va un montón de tiempo en explicar lo mismo cada vez que entra alguien.
              Eso baja. Tu mejor operario vuelve a su máquina antes.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-card-icon">💰</div>
            <h3 class="benefit-card-title">Precio fijo por empresa</h3>
            <p class="benefit-card-desc">
              Desde 49€ al mes por empresa. No sube porque metas más operarios, así que
              puedes empezar por dos o tres procesos críticos y ver si encaja antes de ir a por todo.
            </p>
          </div>
        </div>

        <div class="steps-cta fade-up delay-2">
          <a href="/como-funciona/" class="btn-ghost">Ver cómo funciona →</a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ CTA FINAL ═══ -->
    <section class="cta-section">
      <div class="cta-eyebrow fade-up">¿Quieres verlo en tu planta?</div>
      <div class="cta-title fade-up delay-1">
        Empieza por el puesto<br><em>que más te tensiona hoy</em>
      </div>
      <p class="cta-sub fade-up delay-2">
        Entra en la plataforma, revísala por dentro y valora si encaja con tu operación.
        Sin rodeos: verás rápido si te ayuda a bajar dependencia y ordenar turnos.
      </p>
      <div class="cta-actions fade-up delay-3">
        <a href="https://app.gmvsolutions.es/registro" class="btn-primary"
           data-cta data-cta-intent="registro" data-cta-location="footer" data-cta-label="Registrarme en REELEVO">
          Registrarme en REELEVO
        </a>
        <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost"
           data-cta data-cta-intent="diagnostico" data-cta-location="footer" data-cta-label="Evaluar mi situacion">
          Evaluar mi situación →
        </a>
      </div>
      <div class="cta-note fade-up delay-4">
        Precio claro · Arranque guiado · Decisión basada en tu operativa real
      </div>
    </section>


</BaseLayout>

<style>
  .casos-header,
  .perfiles-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .casos-header .eyebrow,
  .perfiles-header .eyebrow {
    justify-content: center;
  }
  .casos-header .eyebrow::after,
  .perfiles-header .eyebrow::after {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--orange);
  }
  .casos-header .section-sub,
  .perfiles-header .section-sub {
    margin: 0 auto;
  }

  .dolor-cta {
    text-align: center;
    margin-top: 48px;
  }
  .dolor-cta-note {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--gray2);
    margin-top: 16px;
  }

  .steps-cta {
    text-align: center;
    margin-top: 48px;
  }

  .steps-grid.steps-grid-four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .perfiles-grid.perfiles-grid-four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  @media (max-width: 1200px) {
    .steps-grid.steps-grid-four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .perfiles-grid.perfiles-grid-four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .visual-proof-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .steps-grid.steps-grid-four {
      grid-template-columns: 1fr;
    }

    .perfiles-grid.perfiles-grid-four {
      grid-template-columns: 1fr;
    }

    .visual-proof-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Screenshots carousel */
  :root {
    --carousel-autoplay-ms: 3000;
  }
  .screenshots-wrap {
    position: relative;
    margin: 48px 0 0;
    overflow: hidden;
  }

  .screenshots-track {
    display: flex;
    transition: transform .4s ease;
    will-change: transform;
  }

  .screenshot-slide {
    flex-shrink: 0;
    /* width set by JS to match wrapper exactly */
  }

  .screenshot-frame {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .screenshot-frame img {
    width: 100%;
    height: auto;
    display: block;
  }

  .screenshot-caption {
    font-size: .82rem;
    color: var(--gray);
    text-align: center;
    margin-top: 16px;
    line-height: 1.5;
  }

  .carousel-btn {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--white);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .2s, border-color .2s;
    z-index: 2;
  }

  .carousel-btn:hover {
    background: var(--surface);
    border-color: var(--border-hover);
  }

  .carousel-prev { left: 8px; }
  .carousel-next { right: 8px; }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background .2s;
  }

  .carousel-dot.is-active {
