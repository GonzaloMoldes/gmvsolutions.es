---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Dozuki vs REELEVO — Comparativa de software SOP para pymes industriales";
const description = "Comparativa de software de instrucciones de trabajo: Dozuki vs REELEVO en idioma, precio, implantación y adopción para pyme industrial española.";
const canonical = "https://gmvsolutions.es/vs-dozuki/";

const schema = {
  "@context": "https://schema.org",
  "@type": "ComparisonChart",
  "headline": title,
  "description": description,
  "url": canonical,
  "inLanguage": "es-ES",
  "about": [
    {
      "@type": "SoftwareApplication",
      "name": "REELEVO"
    },
    {
      "@type": "SoftwareApplication",
      "name": "Dozuki"
    }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema} activeNav="" pageType="comparativa">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Comparativa de herramientas</div>
    <h1 class="fade-up delay-1">Dozuki vs REELEVO<br><em>¿Cuál es mejor para tu pyme?</em></h1>
    <p class="fade-up delay-2">Comparación en 5 criterios para pyme industrial: idioma, precio, implantación, adopción del operario y encaje real.</p>
    <div class="hero-cta-group fade-up delay-3" style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:24px;">
      <a href="#comparativa" class="btn-primary"
         data-cta data-cta-intent="navegacion" data-cta-location="hero" data-cta-label="Comparar criterios">Comparar criterios</a>
      <a href="https://app.gmvsolutions.es/registro" class="btn-ghost"
         data-cta data-cta-intent="registro" data-cta-location="hero" data-cta-label="Registrarme en REELEVO">Registrarme en REELEVO</a>
    </div>
  </section>

  <div class="divider"></div>

  <!-- COMPARATIVA DIRECTA -->
  <section class="section" id="comparativa">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Comparación directa</div>
        <h2 class="section-title">5 criterios clave para pyme industrial</h2>
      </div>

      <div class="comparison-table fade-up delay-1">
        <table>
          <thead>
            <tr>
              <th style="width: 30%;">Criterio</th>
              <th style="width: 35%;">Dozuki</th>
              <th style="width: 35%;">REELEVO</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Idioma nativo</strong></td>
              <td>Inglés (español parcial)</td>
              <td class="highlight">✓ Español nativo</td>
            </tr>
            <tr>
              <td><strong>Precio</strong></td>
              <td>Bajo demanda (demo)</td>
              <td class="highlight">✓ Público, desde 49€/mes por empresa</td>
            </tr>
            <tr>
              <td><strong>Implantación / arranque</strong></td>
              <td>Proyecto orientado a enterprise</td>
              <td class="highlight">✓ Ligera y asistida</td>
            </tr>
            <tr>
              <td><strong>Adopción del operario</strong></td>
              <td>Curva media-alta</td>
              <td class="highlight">✓ Acceso por QR, sin cuentas por operario</td>
            </tr>
            <tr>
              <td><strong>Encaje pyme industrial española</strong></td>
              <td>Global / enterprise</td>
              <td class="highlight">✓ Pensado para pyme industrial española</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ANÁLISIS DETALLADO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Análisis detallado</div>
        <h2 class="section-title">Dónde difieren</h2>
      </div>

      <div class="comparison-cards fade-up delay-1">
        <div class="comparison-card">
          <h3>Dozuki: Fortalezas</h3>
          <ul>
            <li>Líder global en software SOP</li>
            <li>Amplia base de usuarios internacionales</li>
            <li>Integración con muchos sistemas enterprise</li>
            <li>Comunidad activa con recursos</li>
            <li>Bueno para empresas grandes multiidioma</li>
          </ul>
        </div>

        <div class="comparison-card">
          <h3>Dozuki: Debilidades</h3>
          <ul>
            <li>Precio no transparente</li>
            <li>Diseñado para manufactura global, no pymes</li>
            <li>Interfaz en inglés (barrera en España)</li>
            <li>Soporte en inglés principalmente</li>
            <li>Curva aprendizaje alta para operarios</li>
            <li>Overkill de features para pymes</li>
          </ul>
        </div>

        <div class="comparison-card">
          <h3>REELEVO: Fortalezas</h3>
          <ul>
            <li>Precio transparente (49€-99€/mes)</li>
            <li>Diseñado para pymes industriales españolas</li>
            <li>Interfaz 100% en español</li>
            <li>Soporte 100% en español</li>
            <li>Incluye gestión de competencias</li>
            <li>Simple para operarios (acceso en máquina)</li>
            <li>Onboarding integrado</li>
          </ul>
        </div>

        <div class="comparison-card">
          <h3>REELEVO: Desarrollo</h3>
          <ul>
            <li>Comunidad más pequeña (en crecimiento)</li>
            <li>Menos integraciones enterprise (no las necesita pyme típica)</li>
            <li>Enfoque exclusivo en pymes (no es escala para multinacionales)</li>
            <li>Más reciente que Dozuki en mercado</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CASOS DE USO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">¿Cuándo elegir cada uno?</h2>
      </div>

      <div class="use-case-grid fade-up delay-1">
        <div class="use-case-card">
          <h3>Elige Dozuki si...</h3>
          <ul>
            <li>Eres una empresa grande (500+ empleados)</li>
            <li>Tienes operaciones en múltiples países</li>
            <li>Necesitas integraciones complejas enterprise</li>
            <li>Tienes presupuesto ilimitado IT</li>
            <li>Tu equipo es multiidioma y prefiere inglés</li>
          </ul>
        </div>

        <div class="use-case-card highlight">
          <h3>Elige REELEVO si...</h3>
          <ul>
            <li>Eres pyme industrial (10-200 empleados)</li>
            <li>Operas principalmente en España</li>
            <li>Necesitas precio transparente y predecible</li>
            <li>Tus operarios son hispanohablantes</li>
            <li>Quieres onboarding + SOP + competencias</li>
            <li>Necesitas implementación rápida</li>
            <li>Presupuesto IT limitado</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">Siguiente paso</div>
    <h3 class="cta-title fade-up delay-1">
      ¿Listo para probar <em>REELEVO</em>?
    </h3>
    <p class="cta-sub fade-up delay-2">
      REELEVO está diseñado específicamente para pymes industriales españolas. Sin sorpresas de precio, con soporte en español y enfoque operativo.
    </p>
    <div class="cta-actions fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary"
         data-cta data-cta-intent="registro" data-cta-location="footer" data-cta-label="Registrarse gratis">
        Registrarse gratis
      </a>
      <a href="/precios/" class="btn-ghost">
        Ver precios →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .comparison-table {
    overflow-x: auto;
    margin-top: 40px;
  }

  .comparison-table table {
    width: 100%;
    border-collapse: collapse;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .comparison-table th,
  .comparison-table td {
    padding: 16px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  .comparison-table th {
    background: var(--surface2);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }

  .comparison-table td.highlight {
    background: rgba(255, 150, 0, 0.05);
    color: var(--orange);
    font-weight: 500;
  }

  .comparison-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .comparison-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .comparison-card h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    margin-bottom: 16px;
    color: var(--text);
  }

  .comparison-card ul {
    list-style: none;
    padding: 0;
  }

  .comparison-card li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .comparison-card li:before {
    content: "→ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  .use-case-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .use-case-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .use-case-card.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .use-case-card h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    margin-bottom: 16px;
  }

  .use-case-card.highlight h3 {
    color: var(--orange);
  }

  .use-case-card ul {
    list-style: none;
    padding: 0;
  }

  .use-case-card li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .use-case-card li:before {
    content: "✓ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  .cost-comparison {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .cost-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .cost-card.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .cost-card h4 {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    margin-bottom: 12px;
  }

  .cost-amount {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--orange);
    margin-bottom: 4px;
  }

  .cost-note {
    font-size: 0.85rem;
    color: var(--gray2);
    margin-bottom: 16px;
  }

  .cost-card ul {
    list-style: none;
    padding: 0;
    font-size: 0.9rem;
    color: var(--gray);
  }

  .cost-card li {
    padding: 6px 0;
    border-top: 1px solid var(--border);
    padding-top: 12px;
  }

  .cost-card li:first-child {
    border: none;
    padding-top: 0;
  }

  .roi-note {
    background: rgba(255, 150, 0, 0.08);
    border-left: 4px solid var(--orange);
    padding: 20px;
    border-radius: 4px;
    margin-top: 40px;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .comparison-cards,
    .use-case-grid,
    .cost-comparison {
      grid-template-columns: 1fr;
    }

    .comparison-table {
      font-size: 0.85rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 12px;
    }
  }
</style>
