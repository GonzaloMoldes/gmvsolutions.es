---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Software de gestión para pyme industrial | REELEVO";
const description = "Software de gestión para pymes industriales: producción, competencias, mantenimiento y procesos de planta en una sola herramienta. No es un ERP de contabilidad: gestiona las operaciones del taller.";
const canonical = "https://gmvsolutions.es/software-gestion-pyme-industrial/";

const faqs = [
  {
    q: "¿REELEVO es un software de gestión para pymes?",
    a: "Sí, pero acotado: es un software de gestión para pymes industriales enfocado en las operaciones de planta (producción, competencias, procesos y mantenimiento). No es un software de gestión administrativa ni un ERP de contabilidad o facturación.",
  },
  {
    q: "¿Sirve como software de empresa o necesito un ERP?",
    a: "Depende de lo que busques. Si necesitas contabilidad, nóminas o facturación, eso es un ERP y REELEVO no lo sustituye. Si lo que quieres es un software de empresa para gestionar lo que pasa en el taller —quién produce qué, con qué procedimiento y con qué formación—, REELEVO lo cubre y se integra con tu ERP por API.",
  },
  {
    q: "¿Qué incluye la gestión de pymes industriales con REELEVO?",
    a: "Control de producción en tiempo real, matriz de competencias y polivalencia, documentación de procesos (SOP) en el puesto, planes de mantenimiento preventivo y planificación semanal de turnos. Todo conectado y sin papel.",
  },
  {
    q: "¿Es un software para una empresa de cualquier sector?",
    a: "Está diseñado para la pyme industrial: talleres, fabricación, mecanizado, alimentación y producción en general. No es un software genérico para una empresa de servicios u oficina; su valor está en la planta.",
  },
  {
    q: "Busco «software de empresa» genérico, ¿es esto?",
    a: "Si tu búsqueda fue «software empresa» o «empresa software» y lo que necesitas es administración, contabilidad o finanzas, eso es un ERP horizontal y REELEVO no lo es. REELEVO es el software que gestiona las operaciones de planta de tu empresa industrial, y se integra con el ERP que ya uses.",
  },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "REELEVO - Software de gestión para pyme industrial",
    "description": description,
    "url": canonical,
    "applicationCategory": "BusinessApplication",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema} activeNav="" pageType="capacidad">

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Software de gestión para pyme industrial</div>
    <h1 class="fade-up delay-1">El software de gestión<br><em>que vive en la planta, no en la oficina</em></h1>
    <p class="fade-up delay-2">REELEVO es el software de gestión para pymes industriales que reúne producción, competencias, procesos y mantenimiento en una sola herramienta. No sustituye a tu ERP de contabilidad: gestiona lo que tu ERP no ve — lo que de verdad pasa en el taller.</p>
    <div class="hero-cta fade-up delay-3" style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
      <a href="/video-demo/" class="btn-primary"
         data-cta data-cta-intent="demo" data-cta-location="hero" data-cta-label="Solicitar demo">Solicitar demo</a>
      <a href="https://app.gmvsolutions.es/registro" class="btn-ghost"
         data-cta data-cta-intent="registro" data-cta-location="hero" data-cta-label="Registrarse gratis">Registrarse gratis</a>
    </div>
  </section>

  <div class="divider"></div>

  <!-- POSICIONAMIENTO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Qué tipo de software es</div>
        <h2 class="section-title">Un software de gestión para pymes, no un ERP genérico</h2>
        <p class="section-sub">Cuando una pyme industrial busca «software de gestión» o «software de empresa», suele encontrar ERPs horizontales pensados para administración y finanzas. REELEVO ataca el otro lado: la gestión de las operaciones de planta.</p>
      </div>

      <div class="split-grid fade-up delay-1">
        <div class="split-cell">
          <h3>Lo que SÍ gestiona REELEVO</h3>
          <ul>
            <li>Producción por operario, proceso y máquina, en tiempo real</li>
            <li>Competencias y polivalencia de la plantilla</li>
            <li>Procedimientos de trabajo (SOP) en el puesto, con QR</li>
            <li>Mantenimiento preventivo y órdenes de trabajo</li>
            <li>Planificación semanal de turnos y cobertura</li>
          </ul>
        </div>
        <div class="split-cell muted">
          <h3>Lo que NO es</h3>
          <ul>
            <li>No es contabilidad, facturación ni nóminas</li>
            <li>No es un ERP horizontal de gestión administrativa</li>
            <li>No es un software para una empresa de oficina o servicios</li>
            <li>No te obliga a un proyecto MES de meses</li>
          </ul>
          <p class="muted-note">¿Ya tienes ERP? REELEVO se conecta por API y le aporta el dato de planta que hoy le falta.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- MÓDULOS / ENLACES INTERNOS -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Todo en una herramienta</div>
        <h2 class="section-title">La gestión de la pyme industrial, módulo a módulo</h2>
        <p class="section-sub">Empieza por lo que más te aprieta y añade el resto cuando quieras. Cada módulo funciona solo y mejor en conjunto.</p>
      </div>

      <div class="module-grid fade-up delay-1">
        <a class="module-cell" href="/control-produccion/">
          <h3>Control de producción</h3>
          <p>Registro en tiempo real, paradas con causa y KPIs del día sin partes en papel.</p>
        </a>
        <a class="module-cell" href="/gestion-competencias/">
          <h3>Gestión de competencias</h3>
          <p>Matriz de polivalencia, certificaciones y alertas de cobertura por proceso.</p>
        </a>
        <a class="module-cell" href="/documentacion-procesos/">
          <h3>Documentación de procesos</h3>
          <p>SOP paso a paso en máquina que el operario realmente consulta.</p>
        </a>
        <a class="module-cell" href="/mantenimiento/">
          <h3>Mantenimiento preventivo</h3>
          <p>Planes por máquina y órdenes automáticas en la agenda del operario.</p>
        </a>
        <a class="module-cell" href="/cobertura-turnos/">
          <h3>Planificación y turnos</h3>
          <p>Planificación semanal con alerta antes de que un turno se quede corto.</p>
        </a>
        <a class="module-cell" href="/api-integraciones/">
          <h3>Integraciones</h3>
          <p>Conecta con tu ERP, Power BI y Teams. El dato de planta donde lo necesitas.</p>
        </a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- FAQ -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Preguntas frecuentes</div>
        <h2 class="section-title">Software de gestión para pymes industriales: dudas habituales</h2>
      </div>

      <div class="faq-list fade-up delay-1">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">Gestión de planta, sin papel</div>
    <div class="cta-title fade-up delay-1">
      El software de gestión<br><em>que tu taller sí va a usar</em>
    </div>
    <p class="cta-sub fade-up delay-2">
      Prueba REELEVO y empieza a gestionar producción, competencias y procesos desde un único sitio — sin montar un ERP ni un proyecto de meses.
    </p>
    <div class="cta-actions fade-up delay-3">
      <a href="/video-demo/" class="btn-primary"
         data-cta data-cta-intent="demo" data-cta-location="footer" data-cta-label="Solicitar demo">
        Solicitar demo
      </a>
      <a href="/precios/" class="btn-ghost">
        Ver precios →
      </a>
    </div>
    <div class="cta-trust fade-up delay-4">Sin tarjeta de crédito · Te acompañamos en la primera configuración</div>
  </section>

</BaseLayout>

<style>
  .split-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  @media (max-width: 640px) {
    .split-grid { grid-template-columns: 1fr; }
  }

  .split-cell {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 24px 28px;
  }

  .split-cell.muted { background: rgba(255, 255, 255, 0.02); }

  .split-cell h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    margin-bottom: 14px;
    color: var(--text);
  }

  .split-cell ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .split-cell ul li {
    font-size: 0.9rem;
    color: var(--gray);
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
  }

  .split-cell ul li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--orange);
  }

  .muted-note {
    margin-top: 16px;
    font-size: 0.85rem;
    color: var(--gray);
    line-height: 1.55;
  }

  /* MODULE GRID */
  .module-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  @media (max-width: 860px) { .module-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .module-grid { grid-template-columns: 1fr; } }

  .module-cell {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 22px 24px;
    text-decoration: none;
    transition: border-color .2s, transform .2s;
  }

  .module-cell:hover { border-color: var(--orange); transform: translateY(-2px); }

  .module-cell h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 0.98rem;
    margin-bottom: 8px;
    color: var(--text);
  }

  .module-cell p {
    font-size: 0.88rem;
    color: var(--gray);
    line-height: 1.55;
    margin: 0;
  }

  /* FAQ */
  .faq-list {
    margin-top: 36px;
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 4px 20px;
  }

  .faq-item summary {
    cursor: pointer;
    padding: 16px 0;
    font-family: 'Oswald', sans-serif;
    font-size: 0.98rem;
    color: var(--text);
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item[open] summary { color: var(--orange); }

  .faq-item p {
    margin: 0 0 16px;
    font-size: 0.92rem;
    color: var(--gray);
    line-height: 1.65;
  }
</style>
