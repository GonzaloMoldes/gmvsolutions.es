---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Knowby vs REELEVO — Comparativa de software de procedimientos";
const description = "Knowby vs REELEVO: comparación por adopción operativa real del operario, idioma, precio e implantación para la pyme industrial española.";
const canonical = "https://gmvsolutions.es/vs-knowby/";

const schema = {
  "@context": "https://schema.org",
  "@type": "ComparisonChart",
  "headline": title,
  "description": description,
  "url": canonical,
  "inLanguage": "es-ES"
};
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema} activeNav="" pageType="comparativa">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Comparativa de herramientas</div>
    <h1 class="fade-up delay-1">Knowby vs REELEVO<br><em>Procedimientos genéricos vs operativos especializados</em></h1>
    <p class="fade-up delay-2">Comparación en 5 criterios para pyme industrial: idioma, precio, implantación, adopción del operario y encaje real.</p>
    <div class="hero-cta-group fade-up delay-3" style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:24px;">
      <a href="#comparativa" class="btn-primary"
         data-cta data-cta-intent="navegacion" data-cta-location="hero" data-cta-label="Comparar criterios">Comparar criterios</a>
      <a href="https://app.gmvsolutions.es/registro" class="btn-ghost"
         data-cta data-cta-intent="registro" data-cta-location="hero" data-cta-label="Registrarme en REELEVO">Registrarme en REELEVO</a>
    </div>
  </section>

  <div class="divider"></div>

  <!-- DIFERENCIA CLAVE -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Diferencia clave</div>
        <h2 class="section-title">Genérico vs especializado</h2>
      </div>

      <div class="key-difference fade-up delay-1">
        <div class="diff-item">
          <h3>Knowby</h3>
          <p class="diff-subtitle">Software de procedimientos general</p>
          <p>Knowby está diseñado para documentar procedimientos en cualquier contexto: administrativo, comercial, industrial. Enfoque B2B genérico, no especializado en manufacturas o pymes.</p>
          <div class="diff-use">
            <strong>Mejor para:</strong> Empresas medianas con procesos mixtos (administrativo + operativo)
          </div>
        </div>

        <div class="diff-item highlight">
          <h3>REELEVO</h3>
          <p class="diff-subtitle">SOP industrial + Onboarding especializado</p>
          <p>REELEVO está hecho para pymes industriales y para nada más. Cada función nace de un problema de planta real —una máquina parada un lunes, una baja que cubrir sin avisar— no de un roadmap genérico.</p>
          <div class="diff-use">
            <strong>Mejor para:</strong> Pymes industriales (10-200 empleados) con problemas de onboarding y dependencia operaria
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- COMPARATIVA CARACTERÍSTICAS -->
  <section class="section" id="comparativa">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">5 criterios clave para pyme industrial</h2>
      </div>

      <div class="comparison-table fade-up delay-1">
        <table>
          <thead>
            <tr>
              <th style="width: 30%;">Criterio</th>
              <th style="width: 35%;">Knowby</th>
              <th style="width: 35%;">REELEVO</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Idioma nativo</strong></td>
              <td>Multiidioma, no español nativo</td>
              <td class="highlight">✓ Español nativo</td>
            </tr>
            <tr>
              <td><strong>Precio</strong></td>
              <td>Bajo demanda (contacto)</td>
              <td class="highlight">✓ Público, desde 49€/mes por empresa</td>
            </tr>
            <tr>
              <td><strong>Implantación / arranque</strong></td>
              <td>Media (1-2 semanas)</td>
              <td class="highlight">✓ Ligera y asistida</td>
            </tr>
            <tr>
              <td><strong>Adopción del operario</strong></td>
              <td>Web, requiere navegador</td>
              <td class="highlight">✓ App + acceso por QR, sin cuentas</td>
            </tr>
            <tr>
              <td><strong>Encaje pyme industrial española</strong></td>
              <td>Genérico, no industrial</td>
              <td class="highlight">✓ Pensado para pyme industrial española</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ANÁLISIS COMPARATIVO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">Fortalezas y debilidades</h2>
      </div>

      <div class="analysis-grid fade-up delay-1">
        <div class="analysis-card">
          <h3>Knowby: Fortalezas</h3>
          <ul>
            <li>Software genérico flexible</li>
            <li>Válido para múltiples sectores</li>
            <li>Interfaz profesional</li>
            <li>Colaboración entre usuarios</li>
            <li>Puede usarse en cualquier tipo de empresa</li>
          </ul>
        </div>

        <div class="analysis-card">
          <h3>Knowby: Debilidades</h3>
          <ul>
            <li>No optimizado para industria</li>
            <li>Sin onboarding especializado</li>
            <li>Sin gestión de competencias</li>
            <li>Precio no transparente (overkill pyme)</li>
            <li>Interfaz en inglés (barrera español)</li>
            <li>Soporte no en español</li>
            <li>Requiere navegador (no app móvil)</li>
            <li>Curva aprendizaje moderada</li>
          </ul>
        </div>

        <div class="analysis-card highlight">
          <h3>REELEVO: Fortalezas</h3>
          <ul>
            <li>Especializado para pymes industriales</li>
            <li>SOP + Onboarding + Competencias integrado</li>
            <li>100% en español (interfaz y soporte)</li>
            <li>Precio transparente (49-99€/mes)</li>
            <li>App móvil nativa para planta</li>
            <li>Offline access en máquina</li>
            <li>Implementación 2 días</li>
            <li>ROI visible en 1-2 meses</li>
          </ul>
        </div>

        <div class="analysis-card highlight">
          <h3>REELEVO: Roadmap</h3>
          <ul>
            <li>Comunidad en crecimiento</li>
            <li>Enfoque exclusivo pymes (no enterprise)</li>
            <li>Mercado principal: España</li>
            <li>Desarrollo continuo basado en feedback pymes</li>
            <li>Menos integraciones que software genérico</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CASO REAL -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">Ejemplo: Pyme alimentaria</h2>
      </div>

      <div class="scenario-compare fade-up delay-1">
        <div class="scenario-box">
          <h4>Con Knowby</h4>
          <ul>
            <li>Documentan procedimientos en inglés (del interfaz)</li>
            <li>Operarios no entienden bien la interfaz</li>
            <li>Se crea documentación pero no se usa en planta</li>
            <li>Inversión sin ROI visible</li>
            <li>Soporte por chat en inglés cuando hay problema</li>
            <li>Dejan de usar después 3 meses</li>
          </ul>
        </div>

        <div class="scenario-box highlight">
          <h4>Con REELEVO</h4>
          <ul>
            <li>Interfaz 100% en español</li>
            <li>Documentan en 2 días el proceso de ensamblado</li>
            <li>Operario nuevo consulta en máquina directamente</li>
            <li>Reducen tiempo de aprendizaje 40%</li>
            <li>Soporte responde en español en 24h</li>
            <li>Se pagan los 49€/mes en la primera semana</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- RECOMENDACIÓN -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">¿Cuándo elegir cada uno?</h2>
      </div>

      <div class="recommendation-boxes fade-up delay-1">
        <div class="rec-box">
          <h3>Elige Knowby si...</h3>
          <ul>
            <li>Eres empresa mediana (100+ empleados)</li>
            <li>Necesitas documentación genérica de procesos</li>
            <li>Trabajas en múltiples sectores</li>
            <li>Tu equipo es multiidioma (inglés OK)</li>
            <li>Presupuesto IT importante</li>
            <li>Necesitas colaboración compleja de equipo</li>
          </ul>
        </div>

        <div class="rec-box highlight">
          <h3>Elige REELEVO si...</h3>
          <ul>
            <li>Eres pyme industrial (10-200 empleados)</li>
            <li>Tienes problema de onboarding operarios</li>
            <li>Necesitas SOP accesible en máquina</li>
            <li>Idioma español crítico</li>
            <li>Presupuesto IT limitado (49€/mes OK)</li>
            <li>Necesitas solución rápida (2 días implementación)</li>
            <li>Dependencia de operarios clave</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">Solución especializada</div>
    <h3 class="cta-title fade-up delay-1">
      REELEVO está hecho para <em>tu pyme industrial</em>
    </h3>
    <p class="cta-sub fade-up delay-2">
      No es software genérico. Está especializado en pymes manufactureras españolas. SOP + Onboarding + Competencias integrado, precio transparente, soporte en español.
    </p>
    <div class="cta-actions fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary"
         data-cta data-cta-intent="registro" data-cta-location="footer" data-cta-label="Registrarse gratis">
        Registrarse gratis
      </a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost"
         data-cta data-cta-intent="diagnostico" data-cta-location="footer" data-cta-label="Evaluar mi situacion">
        Evaluar mi situación →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .key-difference {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .diff-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .diff-item.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .diff-item h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    margin-bottom: 8px;
  }

  .diff-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--orange);
    font-weight: 600;
    margin-bottom: 16px;
  }

  .diff-item p {
    color: var(--gray);
    line-height: 1.6;
    margin-bottom: 16px;
    font-size: 0.95rem;
  }

  .diff-use {
    background: rgba(255, 150, 0, 0.1);
    padding: 12px;
    border-radius: 4px;
    font-size: 0.9rem;
    color: var(--text);
  }

  .comparison-table {
    overflow-x: auto;
    margin-top: 40px;
  }

  .comparison-table table {
    width: 100%;
    border-collapse: collapse;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .comparison-table th,
  .comparison-table td {
    padding: 14px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }

  .comparison-table th {
    background: var(--surface2);
    font-weight: 600;
  }

  .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }

  .comparison-table td.highlight {
    background: rgba(255, 150, 0, 0.05);
    color: var(--orange);
    font-weight: 500;
  }

  .analysis-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .analysis-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .analysis-card.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .analysis-card h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    margin-bottom: 16px;
  }

  .analysis-card ul {
    list-style: none;
    padding: 0;
  }

  .analysis-card li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .analysis-card li:before {
    content: "→ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  .scenario-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .scenario-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .scenario-box.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .scenario-box h4 {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    margin-bottom: 16px;
  }

  .scenario-box ul {
    list-style: none;
    padding: 0;
  }

  .scenario-box li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .scenario-box li:before {
    content: "✓ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  .recommendation-boxes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .rec-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .rec-box.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .rec-box h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    margin-bottom: 16px;
  }

  .rec-box ul {
    list-style: none;
    padding: 0;
  }

  .rec-box li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .rec-box li:before {
    content: "✓ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  @media (max-width: 900px) {
    .key-difference,
    .analysis-grid,
    .scenario-compare,
    .recommendation-boxes {
      grid-template-columns: 1fr;
    }
  }
</style>
