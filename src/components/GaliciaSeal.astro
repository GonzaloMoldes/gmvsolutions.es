---
// "Orgullosamente creado en Galicia" mark shown on every page.
// Bottom-right: coat of arms of Galicia (escudo de Galicia), shield only.
// Self-contained SVG — no external assets. The pride caption lives in the aria-label.
---

<div class="gal-marks">
  <div class="gal-seal" role="img" aria-label="Orgullosamente creado en Galicia">
    <span class="gal-seal__shield">
      <svg viewBox="0 0 140 178" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <clipPath id="galShieldClip">
            <path d="M20,28 L120,28 L120,98
                     C120,134 96,156 70,168
                     C44,156 20,134 20,98 Z" />
          </clipPath>
          <g id="galCross">
            <rect x="-1.7" y="-5.5" width="3.4" height="11" rx="0.6" />
            <rect x="-5.5" y="-1.7" width="11" height="3.4" rx="0.6" />
          </g>
        </defs>

        <!-- Royal crown (sits clearly above the shield) -->
        <g stroke="#9a6c08" stroke-width="1.4" stroke-linejoin="round">
          <!-- points -->
          <path d="M34,22 L30,5 L48,16 L70,2 L92,16 L110,5 L106,22 Z" fill="#f3cb2e" />
          <!-- band -->
          <path d="M32,20 L108,20 L104,32 L36,32 Z" fill="#e8b923" />
        </g>
        <!-- pearls on the tips -->
        <circle cx="30" cy="5" r="3.6" fill="#c8102e" stroke="#9a6c08" stroke-width="0.8" />
        <circle cx="70" cy="2.5" r="4" fill="#c8102e" stroke="#9a6c08" stroke-width="0.8" />
        <circle cx="110" cy="5" r="3.6" fill="#c8102e" stroke="#9a6c08" stroke-width="0.8" />
        <!-- jewels on the band -->
        <circle cx="52" cy="26" r="2.4" fill="#c8102e" />
        <circle cx="70" cy="26" r="2.4" fill="#0a3f8f" />
        <circle cx="88" cy="26" r="2.4" fill="#c8102e" />

        <!-- Azure shield -->
        <path d="M20,28 L120,28 L120,98
                 C120,134 96,156 70,168
                 C44,156 20,134 20,98 Z"
              fill="#0a3f8f" />

        <g clip-path="url(#galShieldClip)">
          <!-- Sacred host above the chalice -->
          <g stroke="#fff" stroke-width="1.4" opacity="0.85">
            <line x1="70" y1="56" x2="70" y2="44" />
            <line x1="70" y1="56" x2="58" y2="48" />
            <line x1="70" y1="56" x2="82" y2="48" />
            <line x1="70" y1="56" x2="52" y2="58" />
            <line x1="70" y1="56" x2="88" y2="58" />
          </g>
          <circle cx="70" cy="58" r="8.5" fill="#fff" />

          <!-- Golden ciborium / chalice -->
          <g fill="#e8b923" stroke="#b8860b" stroke-width="0.8">
            <path d="M55,74 L85,74 Q83,94 70,96 Q57,94 55,74 Z" />
            <circle cx="70" cy="100" r="4.5" />
            <rect x="67.5" y="100" width="5" height="16" />
            <ellipse cx="70" cy="118" rx="13" ry="3.6" />
          </g>

          <!-- Seven silver crosses: 1 top, 3 left, 3 right -->
          <g fill="#fff">
            <use href="#galCross" x="70" y="40" />
            <use href="#galCross" x="40" y="66" />
            <use href="#galCross" x="40" y="90" />
            <use href="#galCross" x="46" y="114" />
            <use href="#galCross" x="100" y="66" />
            <use href="#galCross" x="100" y="90" />
            <use href="#galCross" x="94" y="114" />
          </g>
        </g>
        <path d="M20,28 L120,28 L120,98
                 C120,134 96,156 70,168
                 C44,156 20,134 20,98 Z"
              fill="none" stroke="#e8b923" stroke-width="2.5" />
      </svg>
    </span>
  </div>
</div>

<style>
  .gal-marks {
    font-family: 'Oswald', sans-serif;
  }

  /* ── Escudo de Galicia (bottom-right) ── */
  .gal-seal {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 95;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    animation: galSealIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .gal-seal__shield {
    width: 46px;
    height: auto;
    display: block;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.4));
  }
  .gal-seal__shield svg {
    width: 100%;
    height: auto;
    display: block;
  }

  @keyframes galSealIn {
    from { opacity: 0; transform: translateY(-10px) scale(0.9); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .gal-seal {
      bottom: 14px;
      right: 12px;
    }
    .gal-seal__shield {
      width: 35px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gal-seal {
      animation: none;
    }
  }
</style>
