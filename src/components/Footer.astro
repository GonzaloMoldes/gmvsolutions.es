<style>
  .footer-nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 32px 8px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  @media (max-width: 760px) {
    .footer-nav { grid-template-columns: repeat(2, 1fr); gap: 28px 20px; padding: 36px 24px 4px; }
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col-title {
    font-family: 'Oswald', sans-serif;
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--orange);
    margin-bottom: 4px;
  }

  .footer-col a {
    font-size: .82rem;
    color: var(--gray);
    text-decoration: none;
    line-height: 1.4;
    transition: color .2s;
  }

  .footer-col a:hover { color: var(--white); }

  .footer-legal {
    width: 100%;
    display: flex;
    justify-content: center;
    gap: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    margin-top: 8px;
  }

  .footer-legal a {
    font-size: .72rem;
    color: var(--gray2);
    text-decoration: none;
    font-family: 'DM Mono', monospace;
    letter-spacing: .04em;
    transition: color .2s;
  }

  .footer-legal a:hover {
    color: var(--gray);
  }
</style>
